# This script will remove user profiles from the windows registery and any/all data associated with it.

# Get all user profiles excluding admin or special accounts
Write-Host "Starting Removal Of User Profiles" -ForegroundColor Cyan
$profiles = Get-CimInstance -ClassName Win32_UserProfile | Where-Object {
    -not $_.Special -and 
    $_.LocalPath -ne $null
}

foreach ($profile in $profiles) {
    $username = Split-Path $profile.LocalPath -Leaf

    # Skip profiles: Built-in Administrator, contains "AAA", or system/special accounts
    if ($username -eq "Administrator" -or $username -match "AAA" -or $username -match "BBB" -or
        $username -match "^(Default|Public|LocalService|NetworkService|All Users)$") {
        Write-Host "Skipping profile: $username" -ForegroundColor DarkGray
        continue
    }

    try {
        # Remove profile
        $profile | Remove-CimInstance
        Write-Host "Deleted profile: $username" -ForegroundColor Green
    } catch {
        Write-Host "Failed to delete profile: $username. Error: $_" -ForegroundColor Red
    }
}
Write-Host "Removing User Profiles Complete!" -ForegroundColor Cyan
